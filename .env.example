# Frontend (Vite) env vars - must start with VITE_
VITE_API_BASE_URL=https://api.example.com
VITE_AWS_REGION=us-east-1
VITE_AMPLIFY_ENV=dev
VITE_COGNITO_USER_POOL_ID=your_cognito_user_pool_id
VITE_COGNITO_APP_CLIENT_ID=your_cognito_app_client_id

# Backend/Lambda env vars
AWS_REGION=us-east-1
AMPLIFY_ENV=dev
API_BASE_URL=https://api.example.com
COGNITO_USER_POOL_ID=your_cognito_user_pool_id
COGNITO_APP_CLIENT_ID=your_cognito_app_client_id

# External services
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Notes
# - Do not commit real secrets.
# - Keep values per-environment in untracked .env files.
