{
  "name": "nutripilot",
  "version": "1.0.0",
  "description": "NutriPilot AWS Amplify + React nutrition tracker",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"{src,tests,amplify/backend/function}/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"{src,tests,amplify/backend/function}/**/*.{js,jsx}\" --fix",
    "format": "prettier --write \"{src,tests,public}/**/*.{js,jsx,css,json,md}\"",
    "format:check": "prettier --check \"{src,tests,public}/**/*.{js,jsx,css,json,md}\"",
    "prompt:task": "node scripts/prompts/generate_task_prompt.js",
    "prompt:review": "node scripts/prompts/generate_review_prompt.js",
    "verify": "npm run lint && npm run format:check && npm run test:coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metjanbaduni/NutriPilot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "bugs": {
    "url": "https://github.com/metjanbaduni/NutriPilot/issues"
  },
  "homepage": "https://github.com/metjanbaduni/NutriPilot#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.970.0",
    "@aws-sdk/lib-dynamodb": "^3.970.0",
    "aws-amplify": "^6.15.10",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.3",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "aws-sdk-client-mock": "^4.0.2",
    "babel-jest": "^30.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.37.0",
    "globals": "^15.12.0",
    "eslint-plugin-react": "^7.36.1",
    "jest-environment-jsdom": "^30.2.0",
    "jest": "^30.2.0",
    "nock": "^13.5.6",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.19",
    "vite": "^6.4.1"
  }
}
