{
  "name": "nutripilot",
  "version": "1.0.0",
  "description": "NutriPilot AWS Amplify + React nutrition tracker",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"{src,tests,amplify/backend/function}/**/*.js\"",
    "lint:fix": "eslint \"{src,tests,amplify/backend/function}/**/*.js\" --fix",
    "format": "prettier --write \"{src,tests,public}/**/*.{js,jsx,css,json,md}\"",
    "format:check": "prettier --check \"{src,tests,public}/**/*.{js,jsx,css,json,md}\"",
    "verify": "npm run lint && npm run format:check && npm run test:coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metjanbaduni/NutriPilot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "bugs": {
    "url": "https://github.com/metjanbaduni/NutriPilot/issues"
  },
  "homepage": "https://github.com/metjanbaduni/NutriPilot#readme",
  "dependencies": {
    "aws-amplify": "^6.3.7",
    "openai": "^4.77.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@aws-sdk/client-dynamodb": "^3.687.0",
    "@aws-sdk/lib-dynamodb": "^3.687.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.37.0",
    "globals": "^15.12.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest": "^30.2.0",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.13",
    "vite": "^6.0.2"
  }
}
